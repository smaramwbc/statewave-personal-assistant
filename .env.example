# ── LLM ──────────────────────────────────────────────────────────────────────
LLM_API_KEY=your-llm-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ── Statewave ────────────────────────────────────────────────────────────────
# Optional — only set if you enabled API key auth on your Statewave instance.
# Leave blank for the default self-hosted setup (no auth required).
STATEWAVE_API_KEY=
STATEWAVE_BASE_URL=http://localhost:8100

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ── Demo ─────────────────────────────────────────────────────────────────────
# Maximum tokens Statewave may return per context bundle
STATEWAVE_MAX_TOKENS=800
